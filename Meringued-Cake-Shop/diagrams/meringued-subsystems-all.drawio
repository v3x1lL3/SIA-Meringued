        <mxCell id="e2" edge="1" parent="1" source="cu" target="ua" value="0..1 .. 1&#xa;CRM via linkedAccountId" style="html=1;strokeWidth=1.5;strokeColor=#666666;dashed=1;dashPattern=8 8;endArrow=open;endFill=0;fontSize=11;labelBackgroundColor=#ffffff;exitX=0;exitY=0.45;entryX=1;entryY=0.45">
