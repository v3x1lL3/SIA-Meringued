        <mxCell id="leg" value="Green dashed = behavioral / process link (receipt of goods updates on-hand quantities on stock aggregates). No Vendor class in this system. If persistence differs, treat RestockOrder / RestockLineItem as conceptual aggregates over purchase/expense + adjustment flows." style="shape=note;whiteSpace=wrap;html=1;size=12;fillColor=#f5f5f5;strokeColor=#999999;align=left;spacingLeft=10;fontSize=10;connectable=0" vertex="1" parent="1">
          <mxGeometry x="40" y="568" width="1160" height="56" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
