        </mxCell>
        <mxCell id="n2" value="PublicShopInformation maintainers: 1..* fits several staff accounts when RLS allows multiple publishers. If your deployment restricts policy edits to one admin, redraw this association as 1 — 1." style="shape=note;whiteSpace=wrap;html=1;size=12;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=10;fontSize=10;connectable=0" vertex="1" parent="1">
          <mxGeometry x="330" y="700" width="380" height="52" as="geometry"/>
        </mxCell>
        <mxCell id="n3" value="Customer links to UserAccount through linkedAccountId (CRM / buyer identity). ShopAccessProfile is only for staff roles and permissions — not part of the Customer path." style="shape=note;whiteSpace=wrap;html=1;size=12;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=10;fontSize=10;connectable=0" vertex="1" parent="1">
          <mxGeometry x="40" y="760" width="680" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="n1" value="CakeOrder and payment classes belong to the Orders &amp; Payment subsystem." style="shape=note;whiteSpace=wrap;html=1;size=12;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=10;fontSize=10;connectable=0" vertex="1" parent="1">
          <mxGeometry x="740" y="432" width="400" height="44" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
