        <mxCell id="e1" edge="1" parent="1" source="ua" target="sap" value="0..1&#xa;one-to-one" style="html=1;strokeWidth=1.5;strokeColor=#666666;dashed=1;dashPattern=8 8;endArrow=open;endFill=0;fontSize=11;labelBackgroundColor=#ffffff;exitX=1;exitY=0.45;entryX=0;entryY=0.45">
