        </mxCell>
        <mxCell id="leg" value="This subsystem uses dashed links for optional / process-scoped associations (not every mandatory FK). Multiplicity: 0..1, 1, 1..*. Solid lines on other pages mark strict structural FKs (e.g. Catalog)." style="shape=note;whiteSpace=wrap;html=1;size=12;fillColor=#f5f5f5;strokeColor=#999999;align=left;spacingLeft=10;fontSize=10;connectable=0" vertex="1" parent="1">
